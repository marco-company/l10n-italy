<odoo noupdate="1">
    <record id="ir_cron_fatturhello_import_e_bills" model="ir.cron">
        <field name="name">Import E-Bills from Fatturhello</field>
        <field name="model_id" ref="l10n_it_sdi_channel.model_sdi_channel" />
        <field name="active" eval="False" />
        <field name="numbercall">-1</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="state">code</field>
        <field name="code">
model._fatturhello_import_e_bills_cron()
        </field>
    </record>

    <record id="ir_cron_fatturhello_update_e_invoices_status" model="ir.cron">
        <field
            name="name"
        >Update the status of E-Invoices uploaded to Fatturhello</field>
        <field name="model_id" ref="l10n_it_sdi_channel.model_sdi_channel" />
        <field name="active" eval="False" />
        <field name="numbercall">-1</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="state">code</field>
        <field name="code">
model._fatturhello_update_e_invoices_status_cron()
        </field>
    </record>
</odoo>
